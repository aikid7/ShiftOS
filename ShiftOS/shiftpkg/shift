VERSION="1.0.0"
LOG_FILE="/var/log/shift.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
RESET='\033[0m'

# ─── Auto sudo ───────────────────────────
if [ "$EUID" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

# ─── Parse command and flags ─────────────
CMD=$1
NO_CONFIRM=0
QUIET=0
DRY=0
KEEP_CONFIG=0
ARGS=()
EXCLUDES=()
NEXT_IS_EXCLUDE=0

for arg in "${@:2}"; do
    case "$arg" in
        --no-confirm)     NO_CONFIRM=1 ;;
        --quiet)          QUIET=1 ;;
        --dry)            DRY=1 ;;
        --keep-config)    KEEP_CONFIG=1 ;;
        -e=*|--exclude=*) EXCLUDES+=("${arg#*=}") ;;
        -e|--exclude)     NEXT_IS_EXCLUDE=1 ;;
        *)
            if [ "$NEXT_IS_EXCLUDE" -eq 1 ]; then
                EXCLUDES+=("$arg")
                NEXT_IS_EXCLUDE=0
            else
                ARGS+=("$arg")
            fi
            ;;
    esac
done

PKG="${ARGS[*]}"

# build exclude string for apt
EXCLUDE_STR=""
for ex in "${EXCLUDES[@]}"; do
    EXCLUDE_STR="$EXCLUDE_STR ${ex}-"
done

# ─── Logging ─────────────────────────────
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE" 2>/dev/null
}

# ─── Print helpers ───────────────────────
print_header() {
    [ "$QUIET" -eq 1 ] && return 0
    echo -e "${BOLD}${CYAN}"
    echo -e "  ⚡ ShiftOS Package Manager ${RESET}${BLUE}v${VERSION}${RESET}"
    echo -e "  ${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

print_success() { [ "$QUIET" -eq 0 ] && echo -e "  ${GREEN}✔ $1${RESET}"; log "SUCCESS: $1"; }
print_error()   { [ "$QUIET" -eq 0 ] && echo -e "  ${RED}✘ $1${RESET}"; log "ERROR: $1"; }
print_info()    { [ "$QUIET" -eq 0 ] && echo -e "  ${YELLOW}➜ $1${RESET}"; }
print_warn()    { [ "$QUIET" -eq 0 ] && echo -e "  ${MAGENTA}⚠ $1${RESET}"; }

# ─── Spinner ─────────────────────────────
spinner() {
    local pid=$1
    local msg=$2
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    local status=""
    local pkg=""
    tput civis
    while kill -0 $pid 2>/dev/null; do
        local last_line
        last_line=$(tail -1 /tmp/shift_out.log 2>/dev/null)

        # detect what apt is doing right now
        if echo "$last_line" | grep -q "^Unpacking"; then
            pkg=$(echo "$last_line" | awk '{print $2}' | cut -d: -f1)
            status="${YELLOW}Unpacking${RESET}"
        elif echo "$last_line" | grep -q "^Setting up"; then
            pkg=$(echo "$last_line" | awk '{print $3}' | cut -d: -f1)
            status="${GREEN}Setting up${RESET}"
        elif echo "$last_line" | grep -q "^Preparing"; then
            pkg=$(echo "$last_line" | awk '{print $4}' | cut -d: -f1)
            status="${CYAN}Preparing${RESET}"
        elif echo "$last_line" | grep -q "^Get:"; then
            pkg=$(echo "$last_line" | awk '{print $5}' | cut -d: -f1)
            status="${BLUE}Downloading${RESET}"
        elif echo "$last_line" | grep -q "^Removing"; then
            pkg=$(echo "$last_line" | awk '{print $2}' | cut -d: -f1)
            status="${RED}Removing${RESET}"
        fi

        if [ -n "$pkg" ]; then
            printf "\r  ${CYAN}${frames[$i]}${RESET}  $status ${BOLD}$pkg${RESET}                    "
        else
            printf "\r  ${CYAN}${frames[$i]}${RESET}  ${BOLD}$msg${RESET}                    "
        fi

        i=$(( (i+1) % 10 ))
        sleep 0.08
    done
    tput cnorm
    printf "\r\033[K"
}
# ─── Run apt silently ────────────────────
run_apt() {
    local msg=$1
    shift
    > /tmp/shift_out.log
    DEBIAN_FRONTEND=noninteractive apt-get "$@" -y \
        -o Dpkg::Use-Pty=0 \
        -o Dpkg::Progress-Fancy=0 \
        -o APT::Status-Fd=-1 \
        >> /tmp/shift_out.log 2>&1 &
    local pid=$!
    spinner $pid "$msg"
    wait $pid
    return $?
}

# ─── Confirm prompt ──────────────────────
confirm() {
    [ "$NO_CONFIRM" -eq 1 ] && return 0
    printf "  ${YELLOW}Proceed? [y/N]:${RESET} "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

# ─── Package summary ─────────────────────
show_pkg_summary() {
    local action=$1
    local pkgs=$2

    local dry
    dry=$(DEBIAN_FRONTEND=noninteractive apt-get $action --dry-run $pkgs 2>/dev/null)

    local installing
    installing=$(echo "$dry" | grep "^Inst" | awk '{print $2}')

    local removing
    removing=$(echo "$dry" | grep "^Remv" | awk '{print $2}')
  
    local all_pkgs
    all_pkgs=$(echo "$dry" | grep "^Inst" | awk '{print $2}' | tr '\n' ' ')

    local dl_size
    dl_size=$(apt-cache show $all_pkgs 2>/dev/null | grep "^Size:" | awk '{
        total += $2
    } END {
        if (total > 1048576) printf "%.1f MB", total/1048576
        else if (total > 1024) printf "%.1f KB", total/1024
        else if (total > 0) printf "%s B", total
    }')

    local disk_change
    disk_change=$(apt-cache show $all_pkgs 2>/dev/null | grep "^Installed-Size:" | awk '{
        total += $2
    } END {
        if (total > 1024) printf "+%.1f MB", total/1024
        else if (total > 0) printf "+%s KB", total
    }') 

    local free_disk
    free_disk=$(df -h / | awk 'NR==2 {print $4}')

    if [ -n "$installing" ]; then
        echo -e "\n  ${BOLD}${GREEN}Installing:${RESET}"
        echo "$installing" | awk '{printf "  \033[1;32m+\033[0m %-35s\n", $1}'
    fi

    if [ -n "$removing" ]; then
        echo -e "\n  ${BOLD}${RED}Removing:${RESET}"
        echo "$removing" | awk '{printf "  \033[1;31m-\033[0m %-35s\n", $1}'
    fi

    if [ "${#EXCLUDES[@]}" -gt 0 ]; then
        echo -e "\n  ${BOLD}${YELLOW}Excluding:${RESET}"
        for ex in "${EXCLUDES[@]}"; do
            echo -e "  ${YELLOW}~${RESET} $ex"
        done
    fi

    echo -e "\n  ${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "  ${CYAN}Download size :${RESET}  ${BOLD}${dl_size:-unknown}${RESET}"
    echo -e "  ${CYAN}Disk usage    :${RESET}  ${BOLD}${disk_change:-unknown}${RESET}"
    echo -e "  ${CYAN}Free disk     :${RESET}  ${BOLD}$free_disk${RESET}"
    echo -e "  ${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
}

# ─── Commands ────────────────────────────
case "$CMD" in
    install)
        print_header
        if [ -z "$PKG" ]; then print_error "No package specified."; exit 1; fi
        log "Installing: $PKG"
        show_pkg_summary install "$PKG"
        if [ "$DRY" -eq 1 ]; then print_warn "Dry run — nothing installed."; exit 0; fi
        confirm || { print_warn "Aborted."; exit 0; }
        echo ""
        run_apt "Installing $PKG..." install $PKG $EXCLUDE_STR
        [ $? -eq 0 ] && print_success "$PKG installed successfully!" || { print_error "Failed to install $PKG"; cat /tmp/shift_out.log; }
        ;;
    remove)
        print_header
        if [ -z "$PKG" ]; then print_error "No package specified."; exit 1; fi
        log "Removing: $PKG"
        show_pkg_summary remove "$PKG"
        if [ "$DRY" -eq 1 ]; then print_warn "Dry run — nothing removed."; exit 0; fi
        confirm || { print_warn "Aborted."; exit 0; }
        echo ""
        if [ "$KEEP_CONFIG" -eq 1 ]; then
            run_apt "Removing $PKG (keeping configs)..." remove $PKG
        else
            run_apt "Removing $PKG..." purge $PKG
        fi
        [ $? -eq 0 ] && print_success "$PKG removed successfully!" || { print_error "Failed to remove $PKG"; cat /tmp/shift_out.log; }
        ;;
    purge)
        print_header
        if [ -z "$PKG" ]; then print_error "No package specified."; exit 1; fi
        log "Purging: $PKG"
        show_pkg_summary purge "$PKG"
        if [ "$DRY" -eq 1 ]; then print_warn "Dry run — nothing purged."; exit 0; fi
        confirm || { print_warn "Aborted."; exit 0; }
        echo ""
        run_apt "Purging $PKG..." purge $PKG
        [ $? -eq 0 ] && print_success "$PKG purged successfully!" || { print_error "Failed to purge $PKG"; cat /tmp/shift_out.log; }
        ;;
    update)
        print_header
        log "Updating package lists"
        run_apt "Syncing package lists..." update
        [ $? -eq 0 ] && print_success "Package lists up to date!" || { print_error "Update failed."; cat /tmp/shift_out.log; }
        ;;
    upgrade)
        print_header
        log "Upgrading system"
        run_apt "Syncing package lists..." update
        show_pkg_summary upgrade ""
        if [ "$DRY" -eq 1 ]; then print_warn "Dry run — nothing upgraded."; exit 0; fi
        confirm || { print_warn "Aborted."; exit 0; }
        echo ""
        run_apt "Upgrading system..." upgrade
        [ $? -eq 0 ] && print_success "System is up to date!" || { print_error "Upgrade failed."; cat /tmp/shift_out.log; }
        ;;
    search)
        print_header
        if [ -z "$PKG" ]; then print_error "No search term specified."; exit 1; fi
        print_info "Results for \"$PKG\":"
        echo ""
        apt-cache search $PKG | awk -F' - ' '{printf "  \033[1;32m%-30s\033[0m %s\n", $1, $2}'
        ;;
    info)
        print_header
        if [ -z "$PKG" ]; then print_error "No package specified."; exit 1; fi
        apt-cache show $PKG 2>/dev/null | grep -E "^(Package|Version|Installed-Size|Maintainer|Description)" \
            | awk -F': ' '{printf "  \033[1;36m%-20s\033[0m %s\n", $1, $2}' \
            || print_error "Package not found."
        ;;
    list)
        print_header
        if [[ "${ARGS[0]}" == "--installed" ]]; then
            print_info "Installed packages:"
            echo ""
            dpkg -l | grep "^ii" | awk '{printf "  \033[1;32m✔\033[0m %-35s %s\n", $2, $3}'
        else
            print_info "Usage: shift list --installed"
        fi
        ;;
    autoremove)
        print_header
        log "Autoremove"
        show_pkg_summary autoremove ""
        confirm || { print_warn "Aborted."; exit 0; }
        echo ""
        run_apt "Removing unused packages..." autoremove --purge
        [ $? -eq 0 ] && print_success "Unused packages removed!" || { print_error "Autoremove failed."; cat /tmp/shift_out.log; }
        ;;
    clean)
        print_header
        log "Cleaning system"
        run_apt "Cleaning package cache..." clean
        run_apt "Removing unused packages..." autoremove --purge
        [ $? -eq 0 ] && print_success "System cleaned!" || print_error "Clean failed."
        ;;
    log)
        print_header
        print_info "Shift activity log:"
        echo ""
        cat "$LOG_FILE" 2>/dev/null | awk '{printf "  \033[0;36m%s %s\033[0m  %s\n", $1, $2, substr($0, index($0,$3))}' \
            || print_warn "No logs yet."
        ;;
    version)
        echo -e "\n  ${CYAN}${BOLD}⚡ shift${RESET} version ${BOLD}${VERSION}${RESET}\n"
        ;;
    *)
        print_header
        echo -e "  ${BOLD}Usage:${RESET} shift <command> [package] [flags]"
        echo ""
        echo -e "  ${GREEN}install${RESET}     <pkg>         Install a package"
        echo -e "  ${GREEN}remove${RESET}      <pkg>         Remove a package"
        echo -e "  ${GREEN}purge${RESET}       <pkg>         Remove package + configs"
        echo -e "  ${GREEN}update${RESET}                    Sync package lists"
        echo -e "  ${GREEN}upgrade${RESET}                   Upgrade all packages"
        echo -e "  ${GREEN}search${RESET}      <pkg>         Search for a package"
        echo -e "  ${GREEN}info${RESET}        <pkg>         Show package details"
        echo -e "  ${GREEN}list${RESET}        --installed   List installed packages"
        echo -e "  ${GREEN}autoremove${RESET}                Remove unused packages"
        echo -e "  ${GREEN}clean${RESET}                     Clean system cache"
        echo -e "  ${GREEN}log${RESET}                       Show activity log"
        echo -e "  ${GREEN}version${RESET}                   Show version"
        echo ""
        echo -e "  ${BOLD}Flags:${RESET}"
        echo -e "  ${YELLOW}--no-confirm${RESET}              Skip confirmation prompt"
        echo -e "  ${YELLOW}--quiet${RESET}                   No output"
        echo -e "  ${YELLOW}--dry${RESET}                     Simulate only"
        echo -e "  ${YELLOW}--keep-config${RESET}             Keep config files on remove"
        echo -e "  ${YELLOW}-e, --exclude <pkg>${RESET}       Exclude a package"
        echo ""
        ;;
esac
